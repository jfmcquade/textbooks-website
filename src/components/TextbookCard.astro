---
/**
 * TextbookCard — one catalogue entry.
 *
 * Reads ONLY core fields directly (title, authors, description, url). Optional
 * facet values render as chips only when present, so missing/unknown metadata
 * can never break rendering. The card also emits `data-*` attributes that the
 * client-side filter script uses to show/hide it without re-rendering.
 */
import type { Textbook } from '../lib/types';
import { FACET_KEYS } from '../lib/types';
import { searchableText } from '../lib/filtering';

interface Props {
  book: Textbook;
}

const { book } = Astro.props;

// Chips: only the facet values that actually exist on this book.
const chips = FACET_KEYS.map((key) => ({ key, value: book[key] })).filter(
  (c): c is { key: (typeof FACET_KEYS)[number]; value: string } =>
    typeof c.value === 'string' && c.value.length > 0,
);

// Per-facet data attributes consumed by the client filter script.
const facetData: Record<string, string> = {};
for (const key of FACET_KEYS) {
  const value = book[key];
  if (typeof value === 'string') facetData[`data-${key}`] = value;
}

const authorList = book.authors.join(', ');
---

<article
  class="card"
  data-textbook
  data-search={searchableText(book)}
  {...facetData}
>
  <div class="card__body">
    <h3 class="card__title">
      <a href={book.url} target="_blank" rel="noopener noreferrer">
        {book.title}
      </a>
    </h3>

    {
      authorList && (
        <p class="card__authors">{authorList}</p>
      )
    }

    {
      book.description && (
        <p class="card__description">{book.description}</p>
      )
    }
  </div>

  <div class="card__footer">
    {
      chips.length > 0 && (
        <ul class="card__chips" aria-label="Metadata">
          {chips.map((chip) => (
            <li class={`chip chip--${chip.key}`}>{chip.value}</li>
          ))}
        </ul>
      )
    }

    <a
      class="btn btn--primary card__link"
      href={book.url}
      target="_blank"
      rel="noopener noreferrer"
    >
      Open textbook
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: var(--border);
    border-radius: var(--radius);
    background: var(--color-bg);
    padding: var(--space-5);
    transition:
      border-color 0.12s ease,
      box-shadow 0.12s ease;
  }
  .card:hover {
    border-color: var(--color-border-strong);
    box-shadow: 0 1px 3px rgba(24, 24, 27, 0.06);
  }

  .card__body {
    flex: 1 1 auto;
  }

  .card__title {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-1);
  }
  .card__title a {
    color: var(--color-text);
  }
  .card__title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .card__authors {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .card__description {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    /* Clamp to keep the grid tidy; full text remains on the external site. */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__footer {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: var(--border);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .card__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .chip {
    font-size: var(--text-xs);
    font-weight: 500;
    line-height: 1;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .card__link {
    align-self: flex-start;
  }

  @media (min-width: 40rem) {
    .card__footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .card__link {
      align-self: auto;
      flex-shrink: 0;
    }
  }
</style>
